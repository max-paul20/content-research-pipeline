# Gemini API key for analyzer.py and script-generation calls.
GEMINI_API_KEY=

# RapidAPI key for Scraptik TikTok and Instagram scraping endpoints.
RAPIDAPI_KEY=

# Telegram bot token used by delivery.py.
TELEGRAM_BOT_TOKEN=

# Telegram channel ID for internal review and vibe-check scripts.
TELEGRAM_REVIEW_CHANNEL_ID=

# Telegram channel ID for approved scripts that creators should see.
TELEGRAM_CREATOR_CHANNEL_ID=

# Optional overrides for pipeline behavior.
SCRAPE_LIMIT=20
VIRALITY_THRESHOLD=0.7
MAX_GEMINI_CALLS_PER_RUN=20
GEMINI_ANALYSIS_TEMPERATURE=0.3
GEMINI_SCRIPT_TEMPERATURE=0.7
DRY_RUN=false
TEST_MODE=false

# Optional: override the Gemini model and/or its endpoint URL.
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-lite:generateContent

# Optional: override the RapidAPI base URL and individual Scraptik endpoint paths.
# RAPIDAPI_BASE_URL=https://scraptik.p.rapidapi.com
# SCRAPTIK_TIKTOK_TRENDING_ENDPOINT=/tiktok/trending
# SCRAPTIK_TIKTOK_HASHTAG_ENDPOINT=/tiktok/hashtag
# SCRAPTIK_TIKTOK_AUDIO_ENDPOINT=/tiktok/music
# SCRAPTIK_INSTAGRAM_REELS_ENDPOINT=/instagram/reels
# SCRAPTIK_INSTAGRAM_HASHTAG_ENDPOINT=/instagram/hashtag
