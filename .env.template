# ──────────────────────────────────────────────────────────
# Unigliss Trend Radar — Environment Configuration
# ──────────────────────────────────────────────────────────
# Copy to .env and fill in your real keys.
# Never commit .env to version control.

# ── Required API Keys ─────────────────────────────────────

# Gemini API key for Tier 1 analysis (free, aistudio.google.com)
GEMINI_API_KEY=your-key-here

# RapidAPI key for Scraptik TikTok and Instagram scraping endpoints
RAPIDAPI_KEY=your-key-here

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-token-here

# Telegram channel ID for script delivery (private channel)
TELEGRAM_CHANNEL_ID=your-channel-id

# Anthropic API key for Tier 2 script generation (console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-key

# ── Optional Pipeline Behavior ────────────────────────────

SCRAPE_LIMIT=20
MAX_GEMINI_CALLS_PER_RUN=500
GEMINI_ANALYSIS_TEMPERATURE=0.3
SCRIPTS_PER_CAMPUS=3
ANALYZER_TOP_N=15
ANALYZER_MIN_SCORE=50
VIRALITY_THRESHOLD=0.7
DRY_RUN=false
TEST_MODE=false

